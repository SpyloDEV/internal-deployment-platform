APP_NAME="Internal Deployment Platform"
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/internal_deployment_platform
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENABLE_BACKGROUND_JOBS=true
LOG_LEVEL=INFO
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws/deployments
